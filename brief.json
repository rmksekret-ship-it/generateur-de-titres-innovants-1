    "document_html": "<!DOCTYPE html>\n<html lang=\"fr\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Générateur de Titres Innovants | Détails du Sujet</title>\n    <style>\n        :root {\n            --bg-color: #1a1a2e;\n            --card-bg: #2d2d44;\n            --text-color: #e0e0e0;\n            --accent-color: #00bcd4;\n            --border-color: #3f3f5a;\n            --gradient-start: #2d2d44;\n            --gradient-end: #1a1a2e;\n            --mono-font: 'Roboto Mono', monospace;\n            --sans-font: 'Inter', sans-serif;\n        }\n\n        @import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600&family=Roboto+Mono:wght@400&display=swap');\n\n        body {\n            font-family: var(--sans-font);\n            background: linear-gradient(135deg, var(--gradient-start), var(--gradient-end));\n            color: var(--text-color);\n            margin: 0;\n            padding: 0;\n            display: flex;\n            flex-direction: column;\n            align-items: center;\n            min-height: 100vh;\n            line-height: 1.6;\n            overflow-x: hidden;\n        }\n\n        header {\n            width: 100%;\n            padding: 40px 20px;\n            text-align: center;\n            background: rgba(0, 0, 0, 0.2);\n            border-bottom: 1px solid var(--border-color);\n            margin-bottom: 40px;\n        }\n\n        h1 {\n            font-size: 2.8em;\n            color: var(--accent-color);\n            margin-bottom: 10px;\n            letter-spacing: -0.03em;\n        }\n\n        header p {\n            font-size: 1.1em;\n            max-width: 800px;\n            margin: 0 auto;\n            color: #b0b0d0;\n        }\n\n        main {\n            display: grid;\n            grid-template-columns: 1fr;\n            gap: 40px;\n            width: 100%;\n            max-width: 1100px;\n            padding: 0 20px 60px;\n            box-sizing: border-box;\n        }\n\n        .card {\n            background: var(--card-bg);\n            border-radius: 12px;\n            padding: 30px;\n            box-shadow: 0 8px 30px rgba(0, 0, 0, 0.3);\n            border: 1px solid var(--border-color);\n            transition: transform 0.2s ease, box-shadow 0.2s ease;\n            position: relative;\n            overflow: hidden;\n            display: flex;\n            flex-direction: column;\n            gap: 20px;\n        }\n\n        .card::before {\n            content: '';\n            position: absolute;\n            top: -50%;\n            left: -50%;\n            width: 200%;\n            height: 200%;\n            background: radial-gradient(circle at center, rgba(0, 188, 212, 0.1) 0%, transparent 70%);\n            opacity: 0.1;\n            animation: rotate 15s linear infinite;\n        }\n\n        @keyframes rotate {\n            from { transform: rotate(0deg); }\n            to { transform: rotate(360deg); }\n        }\n\n        .tool-section {\n            grid-column: 1;\n        }\n\n        .tool-section h2, .results-section h2 {\n            color: var(--accent-color);\n            font-size: 1.8em;\n            margin-bottom: 25px;\n            border-bottom: 2px solid rgba(0, 188, 212, 0.3);\n            padding-bottom: 10px;\n        }\n\n        label {\n            display: block;\n            margin-bottom: 10px;\n            font-weight: 600;\n            color: #c0c0e0;\n        }\n\n        input[type=\"text\"], textarea, select {\n            width: calc(100% - 24px);\n            padding: 12px;\n            margin-bottom: 20px;\n            border: 1px solid var(--border-color);\n            border-radius: 8px;\n            background-color: var(--gradient-start);\n            color: var(--text-color);\n            font-size: 1em;\n            box-shadow: inset 0 1px 3px rgba(0, 0, 0, 0.4);\n            font-family: var(--mono-font);\n        }\n\n        textarea {\n            min-height: 100px;\n            resize: vertical;\n        }\n\n        input[type=\"text\"]::placeholder, textarea::placeholder {\n            color: #777;\n        }\n\n        button {\n            background-color: var(--accent-color);\n            color: var(--bg-color);\n            border: none;\n            padding: 14px 28px;\n            border-radius: 8px;\n            font-size: 1.1em;\n            font-weight: 600;\n            cursor: pointer;\n            transition: background-color 0.3s ease, transform 0.2s ease;\n            box-shadow: 0 4px 15px rgba(0, 188, 212, 0.4);\n        }\n\n        button:hover {\n            background-color: #00d9f4;\n            transform: translateY(-2px);\n        }\n\n        #tool-result {\n            margin-top: 20px;\n            background-color: rgba(0, 0, 0, 0.2);\n            padding: 25px;\n            border-radius: 8px;\n            border: 1px dashed var(--border-color);\n            min-height: 100px;\n            box-shadow: inset 0 2px 10px rgba(0, 0, 0, 0.2);\n            font-family: var(--mono-font);\n            color: #e0e0e0;\n            white-space: pre-wrap;\n            word-wrap: break-word;\n        }\n\n        .result-group {\n            margin-bottom: 25px;\n        }\n\n        .result-group h3 {\n            color: #90d0ff;\n            font-size: 1.3em;\n            margin-bottom: 10px;\n            border-bottom: 1px solid rgba(144, 208, 255, 0.3);\n            padding-bottom: 5px;\n        }\n\n        .result-group ul {\n            list-style: none;\n            padding: 0;\n            margin: 0;\n        }\n\n        .result-group li {\n            background-color: rgba(0, 188, 212, 0.1);\n            padding: 10px 15px;\n            border-radius: 6px;\n            margin-bottom: 8px;\n            border-left: 3px solid var(--accent-color);\n            transition: background-color 0.2s ease;\n            font-size: 0.95em;\n        }\n        \n        .result-group li:hover {\n            background-color: rgba(0, 188, 212, 0.2);\n        }\n\n        .value-prop-section {\n            grid-column: 1;\n            text-align: center;\n        }\n\n        .value-prop-section h2 {\n            font-size: 2em;\n            margin-bottom: 20px;\n            color: #f0f0f0;\n        }\n\n        .value-prop-section .prop-grid {\n            display: grid;\n            grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));\n            gap: 25px;\n            margin-top: 30px;\n        }\n\n        .prop-item {\n            background-color: var(--gradient-start);\n            border-radius: 10px;\n            padding: 25px;\n            text-align: left;\n            border: 1px solid var(--border-color);\n            box-shadow: 0 6px 20px rgba(0, 0, 0, 0.2);\n            transition: transform 0.3s ease, box-shadow 0.3s ease;\n        }\n        \n        .prop-item:hover {\n            transform: translateY(-5px);\n            box-shadow: 0 10px 35px rgba(0, 0, 0, 0.3);\n        }\n\n        .prop-item h3 {\n            color: var(--accent-color);\n            font-size: 1.4em;\n            margin-bottom: 10px;\n        }\n\n        .prop-item p {\n            color: #c0c0e0;\n            font-size: 0.95em;\n        }\n\n        .seo-section {\n            grid-column: 1;\n            background: var(--card-bg);\n            padding: 30px;\n            border-radius: 12px;\n            box-shadow: 0 8px 30px rgba(0, 0, 0, 0.3);\n            border: 1px solid var(--border-color);\n            margin-top: 40px;\n        }\n\n        .seo-section h2 {\n            color: var(--accent-color);\n            font-size: 1.8em;\n            margin-bottom: 20px;\n            border-bottom: 2px solid rgba(0, 188, 212, 0.3);\n            padding-bottom: 10px;\n        }\n\n        .seo-section p {\n            color: #b0b0d0;\n            margin-bottom: 15px;\n            line-height: 1.7;\n        }\n        .seo-section ul {\n            list-style: disc;\n            padding-left: 20px;\n            color: #b0b0d0;\n            margin-bottom: 15px;\n        }\n        .seo-section li {\n            margin-bottom: 8px;\n        }\n\n        @media (min-width: 768px) {\n            main {\n                grid-template-columns: 2fr 1fr;\n            }\n            .tool-section {\n                grid-column: 1 / 2;\n            }\n            .results-section {\n                grid-column: 2 / 3;\n            }\n            .value-prop-section {\n                grid-column: 1 / 3;\n            }\n            .seo-section {\n                grid-column: 1 / 3;\n            }\n        }\n    </style>\n    <meta name=\"description\" content=\"Propulsez votre contenu avec des titres qui captivent. Notre outil analyse vos idées pour générer instantanément des accroches percutantes, optimisées pour l&#x27;engagement et le référencement.\">\n    <meta name=\"robots\" content=\"index, follow\">\n    <link rel=\"canonical\" href=\"https://generateur-de-titres-innovants-1.onrender.com\">\n    <meta property=\"og:title\" content=\"Générateur de Titres Innovants\">\n    <meta property=\"og:description\" content=\"Propulsez votre contenu avec des titres qui captivent. Notre outil analyse vos idées pour générer instantanément des accroches percutantes, optimisées pour l&#x27;engagement et le référencement.\">\n    <meta property=\"og:url\" content=\"https://generateur-de-titres-innovants-1.onrender.com\">\n    <meta property=\"og:type\" content=\"website\">\n    <script type=\"application/ld+json\">{\"@context\": \"https://schema.org\", \"@type\": \"WebApplication\", \"name\": \"Générateur de Titres Innovants\", \"description\": \"Propulsez votre contenu avec des titres qui captivent. Notre outil analyse vos idées pour générer instantanément des accroches percutantes, optimisées pour l'engagement et le référencement.\", \"url\": \"https://generateur-de-titres-innovants-1.onrender.com\", \"applicationCategory\": \"UtilityApplication\", \"operatingSystem\": \"Web Browser\"}</script>\n</head>\n<body data-site-slug=\"generateur-de-titres-innovants-1\" data-runtime-mode=\"analysis_tool\">\n    <header>\n        <h1>Générateur de Titres Ultra-Performants</h1>\n        <p>Propulsez votre contenu avec des titres qui captivent. Notre outil analyse vos idées pour générer instantanément des accroches percutantes, optimisées pour l'engagement et le référencement.</p>\n    </header>\n\n    <main>\n        <section class=\"card tool-section\">\n            <h2>Détails du Sujet</h2>\n            <form id=\"tool-form\">\n                <label for=\"keyword\">Mot-clé principal (ex: \"marketing digital\", \"recettes vegan\")</label>\n                <input type=\"text\" id=\"keyword\" placeholder=\"Saisissez votre mot-clé\" required>\n\n                <label for=\"topic-description\">Décrivez votre contenu en quelques mots</label>\n                <textarea id=\"topic-description\" placeholder=\"Ex: 'un guide pour débutants sur l'investissement immobilier', 'les avantages d'une alimentation saine pour la productivité'\" required></textarea>\n\n                <label for=\"target-audience\">Public Cible (ex: \"entrepreneurs\", \"jeunes parents\", \"passionnés de tech\")</label>\n                <input type=\"text\" id=\"target-audience\" placeholder=\"Qui voulez-vous atteindre?\">\n\n                <button type=\"submit\" id=\"tool-submit\">Générer les Titres</button>\n            </form>\n        </section>\n\n        <section class=\"card results-section\">\n            <h2>Vos Titres Suggestionnés</h2>\n            <div id=\"tool-result\">\n                <p id=\"result-detail\">Vos titres apparaîtront ici après la génération. Préparez-vous à être inspiré !</p>\n            </div>\n        </section>\n\n        <section class=\"card value-prop-section\">\n            <h2>Pourquoi des Titres de Qualité Sont Essentiels ?</h2>\n            <div class=\"prop-grid\">\n                <div class=\"prop-item\">\n                    <h3>Engagement Accru</h3>\n                    <p>Un titre accrocheur est la première étape pour capter l'attention et inciter au clic, augmentant ainsi le temps passé sur votre contenu.</p>\n                </div>\n                <div class=\"prop-item\">\n                    <h3>Visibilité Optimale</h3>\n                    <p>Des titres optimisés améliorent votre référencement naturel (SEO), rendant votre contenu plus facile à trouver sur les moteurs de recherche.</p>\n                </div>\n                <div class=\"prop-item\">\n                    <h3>Crédibilité Renforcée</h3>\n                    <p>Un titre clair et pertinent projette une image professionnelle et fiable de votre marque ou de votre expertise.</p>\n                </div>\n                <div class=\"prop-item\">\n                    <h3>Conversions Améliorées</h3>\n                    <p>Que ce soit pour une vente, une inscription ou un partage, un bon titre prépare le terrain pour une action réussie de la part de votre audience.</p>\n                </div>\n            </div>\n        </section>\n    </main>\n\n    <section class=\"seo-section\">\n        <h2>Optimiser vos Titres : Stratégies pour le Marché Français</h2>\n        <p>Dans le paysage numérique français, un titre bien conçu est la clé de la visibilité et de l'engagement. Notre générateur de titres est conçu pour vous aider à maîtriser l'art de l'accroche, en tenant compte des spécificités du public francophone. Que vous cherchiez des <strong>idées de titres pour blog</strong>, des <strong>accroches YouTube percutantes</strong>, ou des <strong>titres SEO optimisés</strong> pour votre site web, cet outil est votre allié.</p>\n        <p>Un <strong>bon titre d'article</strong> ou de vidéo doit non seulement informer, mais aussi créer un appel à l'action subtil, susciter la curiosité ou promettre une solution. En France, l'approche peut varier :</p>\n        <ul>\n            <li><strong>Titres informatifs et directs</strong> pour les contenus éducatifs et tutoriels.</li>\n            <li><strong>Titres à question</strong> pour engager l'utilisateur et piquer sa curiosité (\"Comment... ?\", \"Pourquoi... ?\").</li>\n            <li><strong>Titres avec chiffres ou listes</strong> (\"5 astuces pour...\", \"Les 10 meilleurs...\"), très efficaces pour le partage.</li>\n            <li><strong>Titres émotionnels ou provocateurs</strong>, à utiliser avec discernement pour des contenus qui visent à faire réagir.</li>\n        </ul>\n        <p>Notre outil vous aide à générer des <strong>idées de titres créatifs</strong>, à reformuler vos <strong>titres pour capter l'attention</strong>, et à trouver des <strong>titres percutants pour réseaux sociaux</strong>. Que vous soyez un rédacteur web, un marketeur digital ou un créateur de contenu, maximisez l'impact de chaque publication avec des titres qui résonnent avec votre audience française. Explorez les variantes \"SEO\", \"Clickbait\", \"Expert\", \"Soft\" et \"Commercial\" pour trouver le ton parfait adapté à votre message et à vos objectifs.</p>\n        <p>Découvrez comment <strong>créer des titres qui attirent</strong> et augmentent votre taux de clics (CTR). Adoptez une approche stratégique pour vos <strong>titres de vidéos</strong>, <strong>titres d'e-mails</strong>, et <strong>titres de publicités</strong> afin de vous démarquer dans la compétition en ligne. Gagner la \"bataille du clic\" commence toujours par un titre irrésistible.</p>\n    </section>\n\n    <script>\n        document.getElementById('tool-form').addEventListener('submit', function(event) {\n            event.preventDefault();\n\n            const keyword = document.getElementById('keyword').value;\n            const topicDescription = document.getElementById('topic-description').value;\n            const targetAudience = document.getElementById('target-audience').value;\n            const resultDiv = document.getElementById('tool-result');\n\n            if (!keyword || !topicDescription) {\n                resultDiv.innerHTML = '<p style=\"color: #ff6b6b;\">Veuillez remplir au moins le mot-clé principal et la description du contenu.</p>';\n                return;\n            }\n\n            const titles = generateTitles(keyword, topicDescription, targetAudience);\n            let htmlContent = '';\n\n            for (const style in titles) {\n                htmlContent += `<div class=\"result-group\"><h3>${style.charAt(0).toUpperCase() + style.slice(1)}</h3><ul>`;\n                titles[style].forEach(title => {\n                    htmlContent += `<li>${title}</li>`;\n                });\n                htmlContent += '</ul></div>';\n            }\n            \n            resultDiv.innerHTML = htmlContent;\n        });\n\n        function generateTitles(keyword, description, audience) {\n            const commonPhrases = [\n                `Le Guide Ultime de ${keyword}`,\n                `Maîtrisez ${keyword} : Le Tutoriel Complet`,\n                `Découvrez les Secrets de ${keyword}`,\n                `${keyword} : Tout ce que Vous Devez Savoir`,\n                `L'Essentiel de ${keyword} pour ${audience || 'Tous'}`,\n                `Révolutionnez Votre Approche de ${keyword}`,\n                `Optimiser ${keyword} : Les Meilleures Pratiques`,\n                `Comment Réussir dans ${keyword} en ${new Date().getFullYear()}`,\n                `Les Erreurs à Éviter en ${keyword}`,\n                `Boostez vos Résultats avec ${keyword}`,\n                `${description.length > 50 ? description.substring(0, 50) + '...' : description} : L'Expertise ${keyword}`,\n            ];\n\n            const seoTitles = [\n                `${keyword} : Guide Complet pour ${audience || 'Débutants'}`,\n                `Tutoriel ${keyword} : Apprenez Facilement`,\n                `Meilleures Stratégies ${keyword} en ${new Date().getFullYear()}`,\n                `${keyword} France : Tendances et Conseils`,\n                `Qu'est-ce que ${keyword} ? Définition et Application`,\n                `${keyword} pour ${audience || 'Entrepreneurs'} : Maximisez Votre Impact`,\n                `Comparatif ${keyword} : Choisissez la Bonne Approche`,\n                `Actualités ${keyword} : Les Dernières Innovations`,\n                `${keyword} : Exemples Concrets et Études de Cas`,\n            ].filter(t => t.includes(keyword));\n\n            const clickbaitTitles = [\n                `😱 Ne Faites JAMAIS Ça avec ${keyword} !`,\n                `Le Secret Choquant de ${keyword} Révélé !`,\n                `Ce que les Experts ne Vous Disent PAS sur ${keyword}`,\n                `Vous Utilisez ${keyword} de la Mauvaise Manière ?`,\n                `La Vérité Inavouable sur ${keyword}`,\n                `Arrêtez Tout : Voici Pourquoi ${keyword} Change la Donne !`,\n                `Évitez cette Erreur FATALE en ${keyword}`,\n                `L'Astuce ${keyword} que Personne ne Connaît`,\n                `Le #1 ${keyword} que Tout le Monde Devrait Utiliser`,\n            ].filter(t => t.includes(keyword));\n\n            const expertTitles = [\n                `Analyse Approfondie de ${keyword} : Perspectives 2024`,\n                `${keyword} : De la Théorie à la Pratique Avancée`,\n                `Méthodologies Innovantes en ${keyword}`,\n                `Cas d'Étude : Succès et Échecs de ${keyword}`,\n                `L'Algorithme de ${keyword} Démystifié`,\n                `Tendances Futures de ${keyword} : Une Vision Proactive`,\n                `Frameworks et Outils pour ${keyword} Performant`,\n                `L'Impact de ${keyword} sur le Marché : Une Étude Détaillée`,\n                `Optimisation Avancée de ${keyword} : Techniques Inédites`,\n            ].filter(t => t.includes(keyword));\n\n            const softTitles = [\n                `Explorer l'Univers de ${keyword} avec Sérénité`,\n                `Votre Chemin Vers la Maîtrise de ${keyword}`,\n                `Cultiver Votre Potentiel avec ${keyword}`,\n                `Petits Pas pour un Grand Changement en ${keyword}`,\n                `Harmonie et Efficacité Grâce à ${keyword}`,\n                `L'Art de ${keyword} : Une Approche Douce`,\n                `S'Épanouir avec ${keyword} : Conseils Bienveillants`,\n                `${keyword} : Laissez-vous Guider`,\n                `Prenez Soin de Votre ${keyword} : Astuces Quotidiennes`,\n            ].filter(t => t.includes(keyword));\n\n            const commercialTitles = [\n                `Augmentez Vos Ventes avec Notre Solution ${keyword}`,\n                `Transformez Votre Entreprise Grâce à ${keyword}`,\n                `${keyword} : L'Investissement Qui Rapporte`,\n                `Découvrez Notre Offre Exclusive ${keyword}`,\n                `Votre Succès Commence avec Notre Expertise ${keyword}`,\n                `Optimisez Vos Profits avec ${keyword} Pro`,\n                `La Plateforme ${keyword} Qui Change Tout`,\n                `Réalisez Vos Objectifs avec Nos Services ${keyword}`,\n                `${keyword} : L'Outil Indispensable pour ${audience || 'Votre Business'}`,\n            ].filter(t => t.includes(keyword));\n\n            return {\n                seo: [...new Set(shuffleArray(seoTitles).slice(0, 3).concat(shuffleArray(commonPhrases).slice(0, 1)))],\n                clickbait: [...new Set(shuffleArray(clickbaitTitles).slice(0, 3).concat(shuffleArray(commonPhrases).slice(0, 1)))],\n                expert: [...new Set(shuffleArray(expertTitles).slice(0, 3).concat(shuffleArray(commonPhrases).slice(0, 1)))],\n                soft: [...new Set(shuffleArray(softTitles).slice(0, 3).concat(shuffleArray(commonPhrases).slice(0, 1)))],\n                commercial: [...new Set(shuffleArray(commercialTitles).slice(0, 3).concat(shuffleArray(commonPhrases).slice(0, 1)))],\n            };\n        }\n\n        function shuffleArray(array) {\n            for (let i = array.length - 1; i > 0; i--) {\n                const j = Math.floor(Math.random() * (i + 1));\n                [array[i], array[j]] = [array[j], array[i]];\n            }\n            return array;\n        }\n    </script>\n<div id=\"qa-smoke-result\" hidden></div>\n<script id=\"farmbuilder-affiliate-helper\">\n(function () {\n  window.__UTILITY_AFFILIATE_MAP = window.__UTILITY_AFFILIATE_MAP || {};\n  document.addEventListener(\"click\", function (event) {\n    const target = event.target.closest(\"[data-affiliate-slot]\");\n    if (!target) return;\n    const slot = target.getAttribute(\"data-affiliate-slot\");\n    const href = window.__UTILITY_AFFILIATE_MAP[slot];\n    if (!href) return;\n    if (target.tagName && target.tagName.toLowerCase() === \"a\") {\n      target.setAttribute(\"href\", href);\n      target.removeAttribute(\"rel\");\n      return;\n    }\n    event.preventDefault();\n    window.open(href, \"_blank\");\n  }, true);\n})();\n</script>\n<script id=\"farmbuilder-functional-qa\">\n(function () {\n  function marker() {\n    let node = document.getElementById(\"qa-smoke-result\");\n    if (node) return node;\n    node = document.createElement(\"div\");\n    node.id = \"qa-smoke-result\";\n    node.hidden = true;\n    document.body.appendChild(node);\n    return node;\n  }\n\n  let qaFinished = false;\n  let qaWatchdog = null;\n\n  function normalize(text) {\n    return String(text || \"\").replace(/\\s+/g, \" \").trim();\n  }\n\n  function findForm() {\n    return document.getElementById(\"tool-form\") || document.querySelector(\"form\");\n  }\n\n  function findResult() {\n    return (\n      document.getElementById(\"tool-result\") ||\n      document.querySelector(\"[data-result]\") ||\n      document.querySelector(\".tool-result, .result-card, .result, .results, .output, .preview, .diagnostic, .analysis\")\n    );\n  }\n\n  function primaryAction(form) {\n    if (!form) return null;\n    return (\n      document.getElementById(\"tool-submit\") ||\n      form.querySelector(\"#tool-submit\") ||\n      form.querySelector(\"[data-primary-action]\") ||\n      form.querySelector(\"button[type=submit]\") ||\n      form.querySelector(\"button\") ||\n      form.querySelector(\"input[type=submit]\")\n    );\n  }\n\n  function resultSignature(node) {\n    if (!node) return \"\";\n    const text = normalize(node.textContent);\n    const html = normalize(node.innerHTML).slice(0, 600);\n    return `${text}||${html}`;\n  }\n\n  function resultHeadline(node) {\n    if (!node) return \"\";\n    const heading = node.querySelector(\"h1, h2, h3, strong, b\");\n    return normalize(heading ? heading.textContent : \"\");\n  }\n\n  function sampleText(field) {\n    const key = `${field.id || \"\"} ${field.name || \"\"} ${field.placeholder || \"\"}`.toLowerCase();\n    if (/email/.test(key)) return \"bonjour@example.com\";\n    if (/url|site|website|lien/.test(key)) return \"https://example.com/offre-solaire\";\n    if (/phone|tel|mobile/.test(key)) return \"0612345678\";\n    if (/ville|city|localisation|location|region|departement|postal/.test(key)) return \"Paris\";\n    if (/orientation/.test(key)) return \"sud\";\n    if (/keyword|theme|topic|sujet|subject/.test(key)) return \"energie solaire domestique\";\n    if (/titre|title/.test(key)) return \"Simulateur solaire maison\";\n    if (/nom|name|project/.test(key)) return \"Projet Horizon\";\n    if (/description|notes|content|message/.test(key)) return \"Maison individuelle exposee sud avec toiture exploitable.\";\n    return field.placeholder || \"France\";\n  }\n\n  function sampleNumber(field) {\n    const key = `${field.id || \"\"} ${field.name || \"\"}`.toLowerCase();\n    if (/inclinaison|angle|slope/.test(key)) return \"30\";\n    if (/surface|size|m2|sqm/.test(key)) return \"28\";\n    if (/annee|year/.test(key)) return \"2024\";\n    if (/prix|price|budget|cost|amount|montant/.test(key)) return \"12000\";\n    const min = Number(field.min || \"\");\n    const max = Number(field.max || \"\");\n    if (Number.isFinite(min) && Number.isFinite(max) && max >= min) {\n      return String(Math.min(max, Math.max(min, min + Math.round((max - min) * 0.35))));\n    }\n    if (Number.isFinite(min)) return String(Math.max(min, 12));\n    if (Number.isFinite(max)) return String(Math.min(max, 12));\n    return field.value || \"12\";\n  }\n\n  function applySample(field) {\n    const tag = (field.tagName || \"\").toLowerCase();\n    const type = (field.type || \"\").toLowerCase();\n    if (field.disabled) return;\n    if (type === \"hidden\" || type === \"submit\" || type === \"button\" || type === \"reset\" || type === \"image\" || type === \"file\") {\n      return;\n    }\n    const currentValue = normalize(field.value);\n    if (tag === \"select\") {\n      if (currentValue) return;\n      const option = Array.from(field.options || []).find((item) => item.value && !item.disabled) || field.options[0];\n      if (option) field.value = option.value;\n      return;\n    }\n    if (type === \"checkbox\") {\n      if (field.checked) return;\n      field.checked = true;\n      return;\n    }\n    if (type === \"radio\") {\n      if (field.checked) return;\n      field.checked = true;\n      return;\n    }\n    if (type === \"date\") {\n      if (currentValue) return;\n      field.value = \"2026-03-01\";\n      return;\n    }\n    if (type === \"email\") {\n      if (currentValue) return;\n      field.value = \"bonjour@example.com\";\n      return;\n    }\n    if (type === \"url\") {\n      if (currentValue) return;\n      field.value = \"https://example.com/offre-solaire\";\n      return;\n    }\n    if (type === \"tel\") {\n      if (currentValue) return;\n      field.value = \"0612345678\";\n      return;\n    }\n    if (type === \"color\") {\n      if (currentValue) return;\n      field.value = \"#2f855a\";\n      return;\n    }\n    if (type === \"number\" || type === \"range\") {\n      if (currentValue) return;\n      field.value = sampleNumber(field);\n      return;\n    }\n    if (currentValue) return;\n    field.value = sampleText(field);\n  }\n\n  function stamp(status, detail, headline, primary) {\n    if (qaFinished) return;\n    qaFinished = true;\n    if (qaWatchdog) {\n      window.clearTimeout(qaWatchdog);\n      qaWatchdog = null;\n    }\n    const node = marker();\n    node.dataset.status = status;\n    node.dataset.mode = \"native-form\";\n    node.dataset.detail = detail || \"\";\n    node.dataset.headline = headline || \"\";\n    node.dataset.primary = primary || \"\";\n    node.dataset.viewport = window.innerWidth <= 640 ? \"mobile\" : \"desktop\";\n    window.setTimeout(function () {\n      try {\n        window.stop();\n      } catch (_error) {}\n    }, 0);\n  }\n\n  function installModalGuards() {\n    const noop = function () {};\n    const approve = function () { return true; };\n    const empty = function () { return \"\"; };\n    try { window.alert = noop; } catch (_error) {}\n    try { window.confirm = approve; } catch (_error) {}\n    try { window.prompt = empty; } catch (_error) {}\n  }\n\n  function triggerAction(form, action) {\n    try {\n      if (typeof form.requestSubmit === \"function\") {\n        form.requestSubmit(action || undefined);\n        return;\n      }\n    } catch (_error) {}\n    if (action && typeof action.click === \"function\") {\n      action.click();\n      return;\n    }\n    form.dispatchEvent(new Event(\"submit\", { bubbles: true, cancelable: true }));\n  }\n\n  function inspectResult(before, attemptsLeft) {\n    const result = findResult();\n    if (!result) {\n      stamp(\"fail\", \"La zone de resultat est introuvable.\", \"\");\n      return;\n    }\n    const after = resultSignature(result);\n    const text = normalize(result.textContent);\n    if (after && after !== before && text.length >= 24) {\n      const primary = result.querySelector(\"a[href], button[data-href], [data-primary-url]\") || document.querySelector(\"#tool-result a[href]\");\n      stamp(\"pass\", \"Le formulaire natif a mis a jour la zone de resultat.\", resultHeadline(result), primary ? (primary.getAttribute(\"href\") || primary.getAttribute(\"data-primary-url\") || \"\") : \"\");\n      return;\n    }\n    if (attemptsLeft > 0) {\n      window.setTimeout(function () {\n        inspectResult(before, attemptsLeft - 1);\n      }, 250);\n      return;\n    }\n    stamp(\"fail\", \"La zone de resultat n'a pas renvoye de contenu exploitable.\", resultHeadline(result));\n  }\n\n  function runSmoke() {\n    const params = new URLSearchParams(window.location.search);\n    if (params.get(\"__qa\") !== \"functional\") return;\n    qaWatchdog = window.setTimeout(function () {\n      stamp(\"fail\", \"QA smoke timed out before the page reported a usable result.\", \"\");\n    }, 7000);\n    const form = findForm();\n    if (!form) {\n      stamp(\"fail\", \"Le formulaire principal est introuvable.\", \"\");\n      return;\n    }\n    const result = findResult();\n    const before = resultSignature(result);\n    installModalGuards();\n    try {\n      form.querySelectorAll(\"input, select, textarea\").forEach(applySample);\n    } catch (error) {\n      stamp(\"fail\", error && error.message ? `QA smoke sample failed: ${error.message}` : \"QA smoke sample failed before submit.\", \"\");\n      return;\n    }\n    const action = primaryAction(form);\n    try {\n      triggerAction(form, action);\n    } catch (error) {\n      stamp(\"fail\", error && error.message ? `QA smoke submit failed: ${error.message}` : \"QA smoke submit failed.\", \"\");\n      return;\n    }\n    inspectResult(before, 10);\n  }\n\n  window.addEventListener(\"error\", function (event) {\n    const message = event && event.message ? event.message : \"JavaScript runtime error during QA smoke.\";\n    stamp(\"fail\", `QA smoke JS error: ${message}`, \"\");\n  }, { once: true });\n\n  window.addEventListener(\"unhandledrejection\", function (event) {\n    const reason = event && event.reason;\n    const detail = typeof reason === \"string\"\n      ? reason\n      : reason && reason.message\n        ? reason.message\n        : \"Unhandled promise rejection during QA smoke.\";\n    stamp(\"fail\", `QA smoke rejection: ${detail}`, \"\");\n  }, { once: true });\n\n  if (document.readyState === \"loading\") {\n    document.addEventListener(\"DOMContentLoaded\", function () {\n      window.setTimeout(runSmoke, 60);\n    }, { once: true });\n  } else {\n    window.setTimeout(runSmoke, 60);\n  }\n})();\n</script>\n</body>\n</html>",
